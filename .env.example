# ============================================================
# POLYMARKET BOT - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================================

# --- WALLET CONFIGURATION ---
# Your EOA private key (hex string, starts with 0x)
PRIVATE_KEY=0x...

# Your wallet address (EOA address)
WALLET_ADDRESS=0x...

# --- SIGNATURE TYPE ---
# 0 = EOA (standard MetaMask wallet — needs POL for gas)
# 1 = POLY_PROXY (Magic Link / Google login exported PK)
# 2 = GNOSIS_SAFE (Gnosis Safe multisig — most common)
SIGNATURE_TYPE=0

# Funder address: your Polymarket profile wallet address
# For EOA (type 0): same as WALLET_ADDRESS
# For Proxy/Gnosis (type 1/2): the proxy address shown on polymarket.com/settings
FUNDER_ADDRESS=0x...

# --- API ENDPOINTS ---
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com
DATA_HOST=https://data-api.polymarket.com

# Polygon RPC URL — default pakai public RPC, bisa ganti dengan Alchemy/Infura untuk lebih stabil
# Gratis: https://polygon-rpc.com
# Alchemy: https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-rpc.com

# --- BOT STRATEGY CONFIGURATION ---
# How often to scan markets (milliseconds)
SCAN_INTERVAL_MS=30000

# Default order size in USD
DEFAULT_ORDER_SIZE=10

# Maximum position size per market (USD)
MAX_POSITION_SIZE=100

# Minimum price to consider buying (0-1)
MIN_BUY_PRICE=0.05

# Maximum price to consider buying (0-1)
MAX_BUY_PRICE=0.95

# Minimum liquidity spread threshold
MAX_SPREAD_THRESHOLD=0.05

# Enable dry-run mode (true = no real orders placed)
DRY_RUN=true

# --- LOGGING ---
LOG_LEVEL=info
LOG_FILE=logs/bot.log
